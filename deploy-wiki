def write_deploy_workflow():
    """Write .github/workflows/deploy.yml."""
    workflow_dir = DEPLOYER_DIR / ".github" / "workflows"
    workflow_dir.mkdir(parents=True, exist_ok=True)
    
    workflow = '''name: Deploy to GitHub Pages
on:
  push:
    branches: [main]
jobs:
  build-and-deploy:
    runs-on: ubuntu-latest
    permissions:
      contents: write
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: 22
      - name: Install dependencies
        run: npm ci
      - name: Build Quartz
        run: npx quartz build
      - name: Deploy to GitHub Pages
        uses: peaceiris/actions-gh-pages@v4
        with:
          github_token: ${{ secrets.GITHUB_TOKEN }}
          publish_dir: ./public
'''
    (workflow_dir / "deploy.yml").write_text(workflow)


def run(cmd, cwd=None, check=True) -> str:
    """Run a shell command and return stdout."""
    result = subprocess.run(cmd, shell=True, cwd=cwd or str(DEPLOYER_DIR),
                           capture_output=True, text=True, timeout=300)
    if check and result.returncode != 0:
        print(f"ERROR: Command failed: {cmd}")
        print(f"stderr: {result.stderr}")
        print(f"stdout: {result.stdout}")
        sys.exit(1)
    return result.stdout.strip()


def main():
    if len(sys.argv) < 2:
        print("Usage: ./deploy-wiki <wiki-folder-name>")
        print()
        print("Examples:")
        print("  ./deploy-wiki \"vijayanagara 15th century\"")
        print("  ./deploy-wiki \"venice 15th and 16th century\"")
        print("  ./deploy-wiki \"dutch republic 16th and 17th century\"")
        print("  ./deploy-wiki --list")
        sys.exit(1)
    
    if sys.argv[1] == "--list":
        print("Available wikis:")
        for d in sorted(HISTORY_DIR.iterdir()):
            if d.is_dir() and (d / "wiki").is_dir() and d.name != "_deployer":
                wiki_files = len(list((d / "wiki").rglob("*.md")))
                print(f"  {d.name}  ({wiki_files} .md files)")
        sys.exit(0)
    
    # Remove trailing slash if user uses tab-completion
    wiki_name = sys.argv[1].rstrip("/")
    wiki_path = HISTORY_DIR / wiki_name
    
    if not wiki_path.is_dir():
        print(f"Error: Wiki folder not found: {wiki_path}")
        print("Use --list to see available wikis.")
        sys.exit(1)
    
    wiki_content_path = wiki_path / "wiki"
    if not wiki_content_path.is_dir():
        print(f"Error: No 'wiki/' subdirectory found in {wiki_name}")
        sys.exit(1)
    
    # ---- Derive names ----
    wiki_slug = slugify(wiki_name)
    repo_name = f"{wiki_slug}-wiki"
    page_title, suffix = compute_title(wiki_name)
    
    print(f"=== Deploying Wiki: {wiki_name} ===")
    print(f"  Repo:    {GITHUB_USER}/{repo_name}")
    print(f"  Title:   {page_title}{suffix}")
    print(f"  URL:     https://{GITHUB_USER}.github.io/{repo_name}/")
    
    # ---- Step 1: Fix wikilinks in YAML ----
    print("\n[1/6] Fixing [[wikilinks]] in YAML frontmatter...")
    fixed = fix_yaml_frontmatter(wiki_content_path)
    if fixed:
        print(f"  Fixed {fixed} file(s)")
    else:
        print("  No fixes needed")
    
    # ---- Step 2: Symlink content ----
    print("\n[2/6] Setting up content symlink...")
    if CONTENT_DIR.is_symlink() or CONTENT_DIR.exists():
        if CONTENT_DIR.is_symlink():
            CONTENT_DIR.unlink()
        else:
            shutil.rmtree(str(CONTENT_DIR))
    CONTENT_DIR.symlink_to(wiki_content_path, target_is_directory=True)
    print(f"  content → {wiki_content_path}")
    
    # ---- Step 3: Write config files ----
    print("\n[3/6] Writing config files...")
    write_config(wiki_slug, page_title, suffix, repo_name)
    write_layout(repo_name)
    write_deploy_workflow()
    print("  quartz.config.ts, quartz.layout.ts, deploy.yml written")
    
    # ---- Step 4: Build ----
    print("\n[4/6] Building site...")
    build_out = run("npx quartz build", check=True)
    # Count pages from the last line of build output
    for line in build_out.split('\n'):
        print(f"  {line}")
    
    # ---- Step 5: Git setup & push ----
    print("\n[5/6] Setting up git and pushing...")
    run("git init", check=False)
    run("git checkout -b main", check=False)
    
    # Write .gitignore
    gitignore = """node_modules/
public/
.DS_Store
content/
"""
    (DEPLOYER_DIR / ".gitignore").write_text(gitignore)
    
    run("git add -A")
    run('git commit -m "Deploy: {}"'.format(wiki_name), check=False)
    
    # Check if remote is correct
    remote_out = run("git remote get-url origin", check=False)
    expected_url = f"https://github.com/{GITHUB_USER}/{repo_name}.git"
    if remote_out and expected_url in remote_out:
        print("  Remote already configured correctly")
    else:
        # Remove any existing remote and set the correct one
        run("git remote remove origin", check=False)
        # Check if repo exists on GitHub
        repo_check = run(f"gh repo view {GITHUB_USER}/{repo_name} --json name", check=False)
        if repo_check and not "not found" in repo_check.lower():
            print(f"  Repo {repo_name} already exists on GitHub")
            run(f"git remote add origin {expected_url}")
        else:
            print(f"  Creating GitHub repo: {repo_name}")
            run(f"gh repo create {repo_name} --public --source=. --remote=origin --push", check=False)
            # If create succeeded with push, skip the later push step
            if run("git remote get-url origin", check=False) == expected_url:
                pass  # already pushed
            else:
                run(f"git remote add origin {expected_url}")
    
    # Push (if not already done by gh repo create --push)
    current_remote = run("git remote get-url origin", check=False)
    if current_remote == expected_url:
        run("git push -u origin main --force")
    
    # ---- Step 6: Enable GitHub Pages ----
    print("\n[6/6] Enabling GitHub Pages...")
    pages_result = run(
        f"gh api repos/{GITHUB_USER}/{repo_name}/pages --method POST "
        f"-f build_type=legacy "
        f"-f source.branch=gh-pages "
        f"-f source.path=/",
        check=False
    )
    if pages_result:
        try:
            data = json.loads(pages_result)
            print(f"  Pages URL: {data.get('html_url', '')}")
        except json.JSONDecodeError:
            if "already" in pages_result.lower():
                print("  Pages already configured")
            else:
                print(f"  Pages response: {pages_result}")
    
    print(f"\n✓ Done! Site will be live at:")
    print(f"  https://{GITHUB_USER}.github.io/{repo_name}/")
    print(f"  (First deploy may take 30-60s; subsequent ones are instant)")


if __name__ == "__main__":
    main()
