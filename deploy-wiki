#!/usr/bin/env python3
"""
Deploy any wiki from ~/hermes/history/ as a GitHub Pages site.

Usage:
    ./deploy-wiki <wiki-folder-name>

Examples:
    ./deploy-wiki "vijayanagara 15th century"
    ./deploy-wiki "venice 15th and 16th century"
    ./deploy-wiki "dutch republic 16th and 17th century"

The script handles both first-time and update deployments.
"""

import os
import re
import sys
import json
import shutil
import subprocess
from pathlib import Path

HISTORY_DIR = Path.home() / "hermes" / "history"
DEPLOYER_DIR = HISTORY_DIR / "_deployer"
CONTENT_DIR = DEPLOYER_DIR / "content"
GITHUB_USER = "rajeshb62"

# Standard ignore patterns for all wikis
IGNORE_PATTERNS = [
    ".obsidian", "private", "templates", "raw", "log.md",
    "Untitled.md", "unextracted-works.md", "wikilinks.md",
    "queries", "SCHEMA.md",
]


def slugify(name: str) -> str:
    """Convert a wiki folder name to a URL-safe slug for the GitHub repo."""
    s = name.lower()
    # Remove trailing century/era markers for shorter slugs
    s = re.sub(r'\s+\d+(st|nd|rd|th)\s+century(\s+and\s+\d+(st|nd|rd|th)\s+century)?$', '', s)
    s = re.sub(r'\s+and\s+', ' ', s)
    # Replace remaining spaces with hyphens, strip non-alphanumeric
    s = re.sub(r'[^a-z0-9\s-]', '', s)
    s = re.sub(r'\s+', '-', s.strip())
    s = re.sub(r'-+', '-', s)
    return s


def compute_title(wiki_name: str) -> tuple[str, str]:
    """Derive page title and suffix from folder name."""
    base = wiki_name
    # Extract century info for suffix
    century_match = re.search(r'(\d+(?:st|nd|rd|th)\s+century(?:\s+and\s+\d+(?:st|nd|rd|th)\s+century)?)', base)
    suffix = ""
    if century_match:
        suffix = " — " + century_match.group(1).capitalize()
        base = base.replace(century_match.group(0), "").strip()
    
    # Clean up remaining connectors
    base = re.sub(r'\s+and\s+', ' and ', base)
    # Remove leading/trailing junk
    base = base.strip(" ,-–").strip()
    
    # Title-case nicely
    title = base.title()
    
    # Special-case corrections
    title = title.replace(" Of ", " of ").replace(" The ", " the ")
    title = title.replace(" And ", " and ")
    
    # Capitalize first word always
    if title and title[0].islower():
        title = title[0].upper() + title[1:]
    
    return title, suffix


def needs_quoting(value: str) -> bool:
    """Check if a YAML scalar value needs quoting for js-yaml compatibility.
    
    js-yaml chokes on:
    - [[wikilinks]] in unquoted strings
    - colons followed by space inside parentheses (flow context)
    - certain special characters in bare strings
    """
    if not value:
        return False
    if value.startswith('"') and value.endswith('"'):
        return False  # already quoted
    if value.startswith("'") and value.endswith("'"):
        return False  # already quoted
    # Check for wikilinks
    if '[[' in value and ']]' in value:
        return True
    # Check for colon-space that could confuse js-yaml in flow context
    if re.search(r':\s', value):
        return True
    # Check for other YAML-tricky characters
    if '{' in value or '}' in value or '[' in value or ']' in value:
        return True
    return False


def quote_yaml_value(value: str) -> str:
    """Quote a YAML scalar value properly, escaping internal quotes."""
    escaped = value.replace('\\', '\\\\').replace('"', '\\"')
    return f'"{escaped}"'


def fix_yaml_frontmatter(wiki_path: Path):
    """Fix YAML frontmatter issues for Quartz/js-yaml compatibility.
    
    Handles:
    1. [[wikilinks]] in see-also fields (must be quoted)
    2. Colons in list items (e.g. sources) that confuse js-yaml
    """
    fixed_files = 0
    for root, dirs, files in os.walk(wiki_path):
        rel = os.path.relpath(root, wiki_path)
        if rel.startswith(('raw', 'assets', '.obsidian', 'queries', 'private', 'templates')):
            continue
        for fname in files:
            if not fname.endswith('.md'):
                continue
            fpath = os.path.join(root, fname)
            with open(fpath, encoding='utf-8') as f:
                content = f.read()
            if not content.startswith('---'):
                continue

            # Quick check: if no problematic patterns, skip
            if '[[' not in content and ']]' not in content and not re.search(r':\s', content):
                continue

            lines = content.split('\n')
            new_lines = []
            in_fm = False
            modified = False
            in_block_list = False
            list_indent = 0
            list_key = None

            i = 0
            while i < len(lines):
                line = lines[i]
                
                # Detect frontmatter start/end
                if i == 0 and line == '---':
                    in_fm = True
                    new_lines.append(line)
                    i += 1
                    continue
                if in_fm and line == '---':
                    in_fm = False
                    new_lines.append(line)
                    i += 1
                    continue

                if not in_fm:
                    new_lines.append(line)
                    i += 1
                    continue

                # --- Inside frontmatter ---
                stripped = line.lstrip()
                indent = len(line) - len(stripped)

                # Detect a new key (non-indented, not a list item)
                key_match = re.match(r'^(\w[\w_-]*):\s*(.*)', line)
                if key_match and indent == 0:
                    in_block_list = False
                    list_key = key_match.group(1)
                    value = key_match.group(2)
                    if value and needs_quoting(value):
                        new_lines.append(f'{list_key}: {quote_yaml_value(value)}')
                        modified = True
                        i += 1
                        continue
                    new_lines.append(line)
                    i += 1
                    continue

                # Detect continuation of multi-line values (indented)
                if indent > 0 and in_block_list and list_key:
                    if needs_quoting(stripped):
                        # This is a continuation of a list item; the whole item needs attention
                        # Actually, for multi-line YAML, js-yaml is generally ok if each line is indented
                        pass
                
                # Handle ` key: [...]` inline flow mappings
                # Nope, let me not overthink this. Handle list items directly.
                
                # Check if this is a block sequence item
                list_match = re.match(r'^(\s*)-\s+(.*)', line)
                if list_match:
                    in_block_list = True
                    item_indent = len(list_match.group(1))
                    item_value = list_match.group(2)
                    if needs_quoting(item_value):
                        new_lines.append(f'{list_match.group(1)}- {quote_yaml_value(item_value)}')
                        modified = True
                        i += 1
                        continue
                
                new_lines.append(line)
                i += 1

            if modified:
                with open(fpath, 'w', encoding='utf-8') as f:
                    f.write('\n'.join(new_lines))
                fixed_files += 1
    
    return fixed_files


